{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build current C file",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-Wall",
                "-Wextra",
                "-std=c17",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "windows": {
                "args": [
                    "-Wall",
                    "-Wextra",
                    "-std=c17",
                    "-g",
                    "${file}",
                    "-o",
                    "${fileDirname}\\${fileBasenameNoExtension}.exe"
                ]
            },
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Compile single .c file with gcc"
        },
        {
            "label": "Build current C++ file",
            "type": "shell",
            "command": "g++",
            "args": [
                "-Wall",
                "-Wextra",
                "-std=c++17",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "windows": {
                "args": [
                    "-Wall",
                    "-Wextra",
                    "-std=c++17",
                    "-g",
                    "${file}",
                    "-o",
                    "${fileDirname}\\${fileBasenameNoExtension}.exe"
                ]
            },
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Compile single .cpp/.cc/.cxx file with g++"
        },
        {
            "label": "Build with Makefile",
            "type": "shell",
            "command": "make",
            "windows": {
                "command": "make"
            },
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Run make in the current file's directory"
        },
        {
            "label": "Build (auto-detect)",
            "type": "shell",
            "command": "if [ -f Makefile ]; then make; elif [[ \"${file}\" == *.c ]]; then gcc -Wall -Wextra -std=c17 -g \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}\"; else g++ -Wall -Wextra -std=c++17 -g \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}\"; fi",
            "windows": {
                "command": "if exist Makefile (make) else (if \"${fileExtname}\"==\".c\" (gcc -Wall -Wextra -std=c17 -g \"${file}\" -o \"${fileDirname}\\${fileBasenameNoExtension}.exe\") else (g++ -Wall -Wextra -std=c++17 -g \"${file}\" -o \"${fileDirname}\\${fileBasenameNoExtension}.exe\"))"
            },
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Auto-detect: Makefile if present, else compile .c with gcc or .cpp/.cc/.cxx with g++"
        }
    ]
}